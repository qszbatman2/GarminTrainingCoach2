// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  password       String?
  name           String?
  garminEmail    String?
  garminPassword String?       // 简单起见MVP先明文/简单加密存储
  metrics        DailyMetric[]
  activities     Activity[]
  backfillJobs   BackfillJob[]
  analysisReports AnalysisReport[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model DailyMetric {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  date       DateTime
  sleepScore Int?
  restingHr  Int?
  hrv        Int?
  stress     Int?
  raw        Json
  createdAt  DateTime @default(now())

  @@unique([userId, date])
}

model Activity {
  id        String   @id @default(cuid())
  garminId  String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  type      String
  distance  Float?
  duration  Float?
  date      DateTime
  raw       Json
  createdAt DateTime @default(now())
}

model BackfillJob {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  status       String
  days         Int
  totalDates   Int
  currentIndex Int      @default(0)
  targetDates  Json
  syncedDates  Json
  skippedDates Json
  failedDates  Json
  message      String?
  lastError    String?
  startedAt    DateTime?
  finishedAt   DateTime?
  heartbeatAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AnalysisReport {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  reportType String
  inputHash  String
  context    Json
  analysis   Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, reportType])
  @@index([userId, updatedAt])
}
